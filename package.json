{
  "name": "vgmos-github-io",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "data:coilcraft:loss:plan": "node scripts/coilcraft/acquire-losses.mjs plan",
    "data:coilcraft:loss:collect": "node scripts/coilcraft/acquire-losses.mjs collect",
    "data:coilcraft:loss:validate": "node scripts/coilcraft/acquire-losses.mjs validate",
    "data:coilcraft:loss:promote": "node scripts/coilcraft/acquire-losses.mjs promote",
    "data:coilcraft:loss:v2:discovery": "node scripts/coilcraft/acquire-losses-v2.mjs discovery-plan",
    "data:coilcraft:loss:v2:plan": "node scripts/coilcraft/acquire-losses-v2.mjs plan",
    "data:coilcraft:loss:v2:refine": "node scripts/coilcraft/acquire-losses-v2.mjs refine",
    "data:coilcraft:loss:v2:merge-refinement": "node scripts/coilcraft/acquire-losses-v2.mjs merge-refinement",
    "data:coilcraft:loss:v2:validate": "node scripts/coilcraft/acquire-losses-v2.mjs validate",
    "data:coilcraft:loss:v2:promote": "node scripts/coilcraft/acquire-losses-v2.mjs promote",
    "data:buck-loss:spice:regenerate": "node scripts/buck-loss/spice/regenerate-goldens.mjs --write",
    "data:buck-loss:spice:verify": "node scripts/buck-loss/spice/regenerate-goldens.mjs --check",
    "data:buck-loss:spice:vendor:acquire": "node scripts/buck-loss/spice/vendor-models.mjs acquire",
    "data:buck-loss:spice:vendor:regenerate": "node scripts/buck-loss/spice/vendor-models.mjs regenerate --id infineon-bsc010n04ls6-280225 && node scripts/buck-loss/spice/vendor-models.mjs regenerate --id epc2090-ltspice-v1.104",
    "data:buck-loss:spice:vendor:verify": "node scripts/buck-loss/spice/vendor-models.mjs verify --id infineon-bsc010n04ls6-280225 && node scripts/buck-loss/spice/vendor-models.mjs verify --id epc2090-ltspice-v1.104",
    "data:buck-loss:spice:vendor:release-check": "node scripts/buck-loss/spice/vendor-models.mjs release-check --id infineon-bsc010n04ls6-280225 && node scripts/buck-loss/spice/vendor-models.mjs release-check --id epc2090-ltspice-v1.104",
    "data:buck-loss:benchmark:write": "node scripts/buck-loss/benchmark-ti-tps40071.mjs --write",
    "data:buck-loss:benchmark:verify": "node scripts/buck-loss/benchmark-ti-tps40071.mjs --check",
    "test:spice:committed": "node --test tests/buck-loss-spice-golden.test.mjs tests/buck-loss-vendor-model.test.mjs",
    "test:spice": "npm run data:buck-loss:spice:verify && npm run data:buck-loss:spice:vendor:verify && npm run test:spice:committed",
    "test:spice:release": "npm run test:spice && npm run data:buck-loss:spice:vendor:release-check",
    "test:unit": "node --test tests/index.js",
    "test:ui": "playwright test",
    "test:ui:live": "SITE_URL=https://vgmos.github.io PLAYWRIGHT_LIVE=1 playwright test",
    "test:links": "bundle exec htmlproofer _site --disable-external",
    "data:coilcraft:check": "node scripts/coilcraft/acquire.mjs check",
    "data:coilcraft:accept": "node scripts/coilcraft/acquire.mjs accept",
    "data:coilcraft:build": "node scripts/coilcraft/acquire.mjs build"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "pdfjs-dist": "5.4.624"
  }
}
